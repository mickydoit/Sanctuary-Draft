<%- include('partials/head') %>
<h1>Fixtures</h1>
<p class="hint">In kickoff order. Each match shows the two nations and, once the draft is done, which player owns them. Times shown in AEST.</p>
<% groups.forEach((g) => { %>
  <section class="fxgroup">
    <h2><%= g.title %></h2>
    <ul class="fixtures">
      <% g.fixtures.forEach((f) => { %>
        <li id="fx-<%= f.id %>" class="fixture <%= f.status === 'finished' ? 'played' : '' %>">
          <div class="fxtop">
            <span class="fxtime"><%= f.time_label %></span>
            <span class="fxtag"><%= f.stage_label %></span>
          </div>
          <div class="teams">
            <span class="team home"><%= f.home_name %></span>
            <span class="score">
              <% if (f.status === 'finished') { %><%= f.home_score %>&ndash;<%= f.away_score %><% } else { %>v<% } %>
            </span>
            <span class="team away"><%= f.away_name %></span>
          </div>
          <div class="owners">
            <span class="<%= f.home_owner ? 'owned' : 'unowned' %>"><%= f.home_owner || '—' %></span>
            <span class="vs">vs</span>
            <span class="<%= f.away_owner ? 'owned' : 'unowned' %>"><%= f.away_owner || '—' %></span>
          </div>
        </li>
      <% }) %>
    </ul>
  </section>
<% }) %>
<%- include('partials/foot') %>
