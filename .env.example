# Postgres connection string.
# On Render this is injected automatically when the DB is linked (see render.yaml).
# Locally, point it at your own Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/worldcup

# Password that protects the admin/draft controls and the score override page.
ADMIN_PASSWORD=change-me

# Secret used to sign session cookies. Render generates this automatically.
SESSION_SECRET=change-me-too

# Live score provider: "sportmonks" (default) or "football-data".
SCORE_PROVIDER=sportmonks

# SportMonks Football API token (https://www.sportmonks.com/). Needs a plan that
# covers the FIFA World Cup. Leave blank to run the test draft without live scores.
SPORTMONKS_TOKEN=
# Optional overrides (defaults shown): World Cup league id and tournament window.
# SPORTMONKS_WC_LEAGUE_ID=26618
# SPORTMONKS_WC_FROM=2026-06-01
# SPORTMONKS_WC_TO=2026-07-31

# Alternative provider: free token from https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# How often to poll the API for score updates (cron syntax). Default: every 5 minutes.
SCORE_SYNC_CRON=*/5 * * * *
